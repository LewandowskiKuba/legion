# ── Tier 1: Default model (bulk simulation rounds, political routing) ─────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# Centrum/lewica personas — domyślnie Claude Sonnet przez Anthropic.
# Aby użyć Qwen3.5 przez OpenRouter (10-15x taniej):
#   MODEL=qwen/qwen3.5-35b-a3b
#   MODEL_PROVIDER=openai
#   MODEL_BASE_URL=https://openrouter.ai/api/v1
#   MODEL_API_KEY=sk-or-v1-...
MODEL=claude-sonnet-4-6
# MODEL_PROVIDER=anthropic   # domyślnie anthropic; zmień na openai dla OpenRouter
# MODEL_API_KEY=             # opcjonalnie: osobny klucz dla centrum modelu
# MODEL_BASE_URL=            # opcjonalnie: np. https://openrouter.ai/api/v1

MODEL_RIGHT=llama-3.3-70b-versatile
MODEL_FAR_RIGHT=meta-llama/llama-4-scout-17b-16e-instruct
MODEL_FAR_LEFT=gpt-5.4-mini

# ── Tier 2: Smart model (GraphRAG, reportAgent, synthesis) ────────────────────
# Domyślnie używa ANTHROPIC_API_KEY. Aby użyć Qwen3.5 przez OpenRouter:
#   SMART_MODEL_NAME=qwen/qwen3.5-27b
#   SMART_PROVIDER=openai
#   SMART_BASE_URL=https://openrouter.ai/api/v1
#   SMART_API_KEY=sk-or-v1-...
SMART_MODEL_NAME=claude-sonnet-4-6
SMART_PROVIDER=anthropic
# SMART_API_KEY=        # opcjonalnie: inny klucz niż domyślny
# SMART_BASE_URL=       # opcjonalnie: self-hosted endpoint

# ── Tier 3: NER model (entity extraction, cheap mechanical tasks) ─────────────
NER_MODEL_NAME=llama-3.1-8b-instant
NER_PROVIDER=groq
# NER_API_KEY=          # opcjonalnie: inny klucz niż GROQ_API_KEY
# NER_BASE_URL=         # opcjonalnie: self-hosted endpoint

# ── Concurrency ───────────────────────────────────────────────────────────────
CONCURRENCY=5

# ── Database (PostgreSQL + pgvector) ──────────────────────────────────────────
POSTGRES_PASSWORD=zmien_to_na_silne_haslo
DATABASE_URL=postgresql://legion:zmien_to_na_silne_haslo@postgres:5432/legion

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
POPULATION_SIZE=7000
